<%# Main container using Flexbox for two columns %>
<div class="flex h-[calc(100vh-150px)] border border-white/10 rounded-2xl bg-white/5 backdrop-blur-xl shadow-2xl overflow-hidden chat-sidebar-container" data-controller="chat-sidebar">

  <%# Left Pane: Chat List Sidebar %>
  <div id="chats-list" class="chat-sidebar w-full md:w-1/4 border-r border-white/10 overflow-y-auto p-4 bg-transparent" data-chat-sidebar-target="sidebar">
    <h2 class="text-lg font-semibold mb-4 text-gray-200">My Chats 💬</h2>

    <%# Button/Form to create a new chat %>
    <%= form_with(model: Chat.new, url: chats_path, method: :post, class: "mb-4") do |f| %>
      <%# You could add fields for title/description/model here if desired %>
      <%# Example: f.text_field :title, placeholder: "Optional Title", class: "..." %>
      <%= f.submit "✨ Start New Chat", class: "w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 hover:from-indigo-600 hover:to-pink-600 transition-all duration-300 transform hover:scale-[1.02] text-white font-bold py-2 px-4 rounded-xl shadow-lg shadow-purple-500/30 cursor-pointer" %>
    <% end %>


    <%# List of existing chats - Render the partial for each chat %>
    <div id="user-chats"> <%# A target for potential Turbo Stream updates to the list %>
      <% if @chats.any? %>
        <% @chats.each do |chat_item| %>
          <%= render partial: "chats/chat_link", locals: { chat_item: chat_item, current_chat: @chat } %>
        <% end %>
      <% else %>
        <p class="text-gray-400 italic">No chats yet. Start a new one!</p>
      <% end %>
    </div>
  </div>

  <%# Right Pane: Chat Window %>
  <div class="chat-content w-full md:w-3/4 flex flex-col">
    <% if @chat %>
      <%# Mobile button to show chat list %>
      <div class="md:hidden p-2 bg-transparent border-b border-white/10">
        <button id="toggle-chats-list" class="w-full bg-gradient-to-r from-indigo-500 to-purple-500 hover:from-indigo-600 hover:to-purple-600 transition-all duration-300 transform hover:scale-[1.02] text-white font-bold py-2 px-4 rounded-xl shadow-lg cursor-pointer" data-action="click->chat-sidebar#toggle">Change Chat</button>
      </div>

      <%# Connect to Turbo Stream for this specific chat's messages %>
      <%= turbo_stream_from [@chat, "messages"] %>

      <div id="<%= dom_id(@chat) %>">
        <%= render @chat %>
      </div>

      <%# Messages Area - Use flex-grow to take available space, overflow-y-auto for scrolling %>
      <div id="messages" class="flex-grow flex flex-col overflow-y-auto p-4 space-y-4 bg-transparent" data-controller="scroll">
        <%# Render existing messages using the message partial %>
        <%= render @messages %>
        <%# New messages will be appended here by Turbo Streams %>
      </div>

      <%# Input Area Form %>
      <div class="p-4 border-t border-white/10 bg-transparent">
        <% if @chat.user_id == current_user.id %>
          <%= form_with(model: [@chat, Message.new], url: chat_messages_path(@chat), method: :post, class: "flex items-center space-x-2") do |f| %>
            <%= f.text_area :content,
                  placeholder: "Ask anything...",
                  class: "flex-grow border border-white/10 bg-black/20 rounded-xl p-3 focus:outline-none focus:ring-2 focus:ring-purple-500 resize-none text-gray-100 placeholder-gray-400 backdrop-blur-sm",
                  rows: 2,
                  data: { controller: 'textarea' } %> <%# Optional: Stimulus for auto-resizing %>
            <%= f.submit "Send 🚀", class: "bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 transition-all duration-300 transform hover:scale-105 shadow-lg shadow-teal-500/30 text-white font-bold py-2 px-4 rounded-xl cursor-pointer" %>
          <% end %>
        <% else %>
          <p class="text-gray-400 italic text-center">😕 You don't own this chat, so you cannot interact with it.</p>
        <% end %>
    </div>

    <% else %>
      <%# Placeholder when no chat is selected %>
      <div class="flex-grow flex items-center justify-center p-4 text-gray-400">
        <p>Select a chat from the left or start a new one! 🎉</p>
      </div>
    <% end %>
  </div>

</div>
