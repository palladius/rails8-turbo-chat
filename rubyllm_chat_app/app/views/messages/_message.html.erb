<%# Renders a single message, used for both initial load and Turbo Streams %>

<%# Use Turbo Frame for potential targeted updates later, and required by streaming approach %>
<%= turbo_frame_tag message do %>
  <%# iPhone-style chat bubbles with Gemini colors %>
  <% role_class = case message.role
                  when "user"
                    "bg-gradient-to-tr from-green-500 to-green-400 text-white self-end ml-auto rounded-2xl rounded-br-sm shadow-md border border-white/10" # User on the right (iPhone green)
                  when "assistant"
                    "bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 text-white self-start mr-auto rounded-2xl rounded-bl-sm shadow-md border border-white/10" # Assistant on the left (Gemini colors)
                  when "system"
                    "bg-black/30 text-gray-300 text-xs italic mx-auto my-2 rounded-2xl border border-white/10" # System centered
                  when "tool"
                    "bg-yellow-700/80 text-yellow-100 text-xs italic self-start mr-auto rounded-2xl rounded-bl-sm shadow-md border border-white/10"
                  else
                    "bg-gray-700/80 text-gray-200 self-start mr-auto rounded-2xl rounded-bl-sm shadow-md border border-white/10"
                  end %>
  
  <div class="message <%= message.role %> <%= role_class %> p-3 md:p-4 max-w-[85%] md:max-w-[75%] mb-2 backdrop-blur-md">
    <% if message.user? || message.role == 'assistant' %>
      <div
        id="<%= dom_id(message, :content) %>"
        class="prose prose-sm md:prose-base max-w-full break-words text-white"
      >
        <%# Render initial content. Streaming will append here. %>
        <%= markdown_to_html(message.content) %>
      </div>
    <% else %>
      <%# System messages are centered and italic %>
      <div
        id="<%= dom_id(message, :content) %>"
        class="prose prose-sm max-w-none break-words text-center"
      >
        <%= markdown_to_html(message.content) %>
      </div>
    <% end %>
  </div>
<% end %>
